{
  "name": "@dvcol/web-extension-template",
  "type": "module",
  "version": "1.8.0",
  "title": "Web Extension Template",
  "packageManager": "pnpm@10.32.1",
  "description": "Web Extension Template",
  "author": "dvcol",
  "license": "MIT",
  "homepage": "https://github.com/dvcol/web-extension-template",
  "repository": {
    "type": "git",
    "url": "https://github.com/dvcol/web-extension-template.git"
  },
  "bugs": "https://github.com/dvcol/web-extension-template/issues",
  "main": "./build/lib/index.js",
  "types": "./build/lib/index.d.ts",
  "files": [
    "*.md",
    "LICENSE",
    "build/lib"
  ],
  "engines": {
    "node": ">=20",
    "pnpm": ">= 7"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prepare": "husky",
    "clear": "rimraf dist",
    "dist": "pnpm run clear && esno scripts/prepare.ts",
    "type:check": "tsc --build tsconfig.app.json",
    "vite:serve": "vite",
    "vite:build": "vite build",
    "vite:preview": "vite preview",
    "dev": "cross-env NODE_ENV=development run-p dist vite:serve",
    "dev:web": "VITE_SOURCEMAP=true VITE_WEB=true VITE_BASE=/trakt-extension/ run-s dev",
    "build": "cross-env NODE_ENV=production run-s dist type:check 'vite:build {@}' --",
    "build:web": "VITE_WEB=true VITE_BASE=/web-extension-template/ pnpm run build",
    "serve:web": "VITE_SOURCEMAP=true VITE_WEB=true VITE_BASE=/web-extension-template/ run-s build vite:preview",
    "build:all": "run-p build build:web",
    "analyse": "VITE_DEVTOOLS=true pnpm run build",
    "test:unit": "vitest run --coverage --mode testing",
    "test:watch": "vitest --mode testing",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint --fix",
    "style": "stylelint '**/*.{css,scss,less,html}' --go '{\"gitignore\":true}'",
    "style:fix": "pnpm run style --fix",
    "release": "standard-version",
    "release:changelog": "extract-changelog-release > RELEASE.md"
  },
  "dependencies": {
    "@dvcol/common-utils": "^1.34.0",
    "@dvcol/web-extension-utils": "^3.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.13.2"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@dvcol/eslint-config": "^1.8.6",
    "@dvcol/stylelint-plugin-presets": "^2.1.3",
    "@eslint-react/eslint-plugin": "^2.11.0",
    "@prettier/plugin-xml": "^3.4.2",
    "@rolldown/plugin-babel": "^0.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/chrome": "^0.1.38",
    "@types/fs-extra": "^11.0.4",
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/devtools": "^0.1.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.0",
    "babel-plugin-react-compiler": "latest",
    "c8": "^11.0.0",
    "chokidar": "^5.0.0",
    "cross-env": "^10.1.0",
    "eslint": "^10.1.0",
    "eslint-plugin-format": "^2.0.1",
    "esno": "^4.8.0",
    "extract-changelog-release": "^1.0.2",
    "fs-extra": "^11.3.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "lint-staged": "^16.4.0",
    "magic-string": "^0.30.21",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.1",
    "rimraf": "^6.1.3",
    "sass": "^1.98.0",
    "standard-version": "^9.5.0",
    "stylelint": "^17.5.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vite-plugin-checker": "^0.12.0",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "webextension-polyfill": "^0.12.0"
  },
  "lint-staged": {
    "*.{js,cjs,mjs,jsx,ts,tsx,json,md,yml,html,md,svg,xml}": [
      "eslint --fix"
    ],
    "*.{css,scss,less}": [
      "stylelint --fix"
    ]
  }
}
